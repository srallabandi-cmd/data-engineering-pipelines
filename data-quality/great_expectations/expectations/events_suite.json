{
  "expectation_suite_name": "events_suite",
  "ge_cloud_id": null,
  "data_asset_type": null,
  "meta": {
    "great_expectations_version": "0.18.8",
    "created_by": "data-engineering",
    "description": "Comprehensive data quality expectations for the events dataset. Validates schema, nullability, value ranges, domains, and cross-column relationships."
  },
  "expectations": [
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {
        "column": "event_id"
      },
      "meta": {
        "purpose": "Ensure the primary key column exists."
      }
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {
        "column": "event_type"
      },
      "meta": {
        "purpose": "Ensure the event type column exists."
      }
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {
        "column": "user_id"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {
        "column": "event_timestamp"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {
        "column": "revenue"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {
        "column": "duration_ms"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "event_id"
      },
      "meta": {
        "severity": "critical",
        "purpose": "event_id is the primary key and must never be null."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "event_type"
      },
      "meta": {
        "severity": "critical"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "event_timestamp"
      },
      "meta": {
        "severity": "critical"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "ingestion_date",
        "mostly": 1.0
      },
      "meta": {
        "severity": "critical"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {
        "column": "event_id"
      },
      "meta": {
        "severity": "critical",
        "purpose": "event_id must be unique across the dataset."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "revenue",
        "min_value": 0.0,
        "max_value": 1000000.0,
        "mostly": 0.99
      },
      "meta": {
        "severity": "warning",
        "purpose": "Revenue should be non-negative and within a reasonable range."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "duration_ms",
        "min_value": 0,
        "max_value": 86400000,
        "mostly": 0.99
      },
      "meta": {
        "severity": "warning",
        "purpose": "Duration should be non-negative and under 24 hours."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "event_type",
        "value_set": [
          "page_view",
          "click",
          "scroll",
          "purchase",
          "signup",
          "login",
          "logout"
        ]
      },
      "meta": {
        "severity": "critical",
        "purpose": "event_type must be one of the known event types."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "device_type",
        "value_set": [
          "mobile",
          "desktop",
          "tablet",
          "smart_tv",
          "bot",
          "other",
          "unknown"
        ],
        "mostly": 0.95
      },
      "meta": {
        "severity": "warning"
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 100,
        "max_value": 100000000
      },
      "meta": {
        "severity": "critical",
        "purpose": "Table should have a reasonable number of rows. Empty or extremely large indicates a pipeline issue."
      }
    },
    {
      "expectation_type": "expect_column_pair_values_a_to_be_greater_than_b",
      "kwargs": {
        "column_A": "event_timestamp",
        "column_B": "ingested_at",
        "or_equal": true,
        "mostly": 0.0
      },
      "meta": {
        "severity": "info",
        "purpose": "Informational: check relationship between event time and ingestion time. Events should generally occur before ingestion."
      }
    },
    {
      "expectation_type": "expect_column_pair_values_a_to_be_greater_than_b",
      "kwargs": {
        "column_A": "ingested_at",
        "column_B": "event_timestamp",
        "or_equal": true,
        "mostly": 0.95
      },
      "meta": {
        "severity": "warning",
        "purpose": "Ingestion time should generally be after event time. High failure rate suggests clock skew."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "user_id",
        "mostly": 0.8
      },
      "meta": {
        "severity": "warning",
        "purpose": "At least 80% of events should have a user_id."
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "event_id",
        "regex": "^[a-zA-Z0-9\\-_]{8,64}$",
        "mostly": 1.0
      },
      "meta": {
        "severity": "critical",
        "purpose": "event_id should be an alphanumeric string between 8 and 64 characters."
      }
    }
  ]
}
